# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# OpenAI — optional AI draft when you choose "Generate build-fix prompt" (option 2).
# Create/revoke keys: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional model for the draft step (default: gpt-4o-mini)
# INTENT_MERGE_MODEL=gpt-4o-mini

# Set to any value to disable ANSI colors in terminal output
# NO_COLOR=1
